{% extends "layout.njk" %}

{% set pageTitle = site.title %}
{% set pageDescription = site.description %}
{% set canonicalUrl = "/" %}
{% set ogType = "website" %}
{% set ogImage = articles[0].image if articles.length > 0 and articles[0].image else "" %}

{% block additionalHead %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "{{ site.title }}",
  "description": "{{ site.description }}",
  {% if author %}"author": {
    "@type": "Person",
    "name": "{{ author.profile.display_name or author.profile.name }}",
    {% if author.profile.about %}"description": {{ author.profile.about | dump | safe }},{% endif %}
    {% if author.profile.picture %}"image": "{{ author.profile.picture }}",{% endif %}
    {% if author.profile.website %}"url": "{{ author.profile.website }}",{% endif %}
    "sameAs": [
      {% if author.npub %}"https://nosta.me/{{ author.npub }}"{% endif %}{% if author.profile.twitter %},{% endif %}
      {% if author.profile.twitter %}"https://twitter.com/{{ author.profile.twitter }}"{% endif %}{% if author.profile.github %},{% endif %}
      {% if author.profile.github %}"https://github.com/{{ author.profile.github }}"{% endif %}
    ]
  },{% endif %}
  "blogPost": [
    {% for article in articles | slice(0, 10) %}
    {
      "@type": "BlogPosting",
      "headline": {{ article.title | dump | safe }},
      {% if article.summary %}"description": {{ article.summary | dump | safe }},{% endif %}
      "url": "/{{ article.slug }}.html",
      "datePublished": "{{ article.published_at | date('iso') }}",
      {% if article.modified_at %}"dateModified": "{{ (article.modified_at * 1000) | date('iso') }}",{% endif %}
      {% if article.image %}"image": "{{ article.image }}",{% endif %}
      "author": {
        "@type": "Person",
        "name": "{{ author.profile.display_name or author.profile.name }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
<style>
  /* ── Index-page styles ──────────────────────────── */

  /* Author block at top */
  .index-author {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .index-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }
  .index-avatar-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--surface-alt);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .index-author-meta { flex: 1; }
  .index-author-name {
    font-size: 1.125rem;
    font-weight: 650;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .index-author-bio {
    margin-top: 0.3rem;
    font-size: 0.9375rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 52ch;
  }

  /* Section heading */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 1.5rem;
  }

  /* ── Article list ─────────────────────────────── */
  .post-list {
    list-style: none;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }
  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-link:hover { opacity: 0.7; }

  .post-link-with-image {
    grid-template-columns: 1fr 80px;
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.4;
    margin-bottom: 0.25rem;
  }

  .post-summary {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--ink-subtle);
  }
  .post-meta-sep { opacity: 0.4; }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }
  .post-tag {
    font-size: 0.75rem;
    color: var(--ink-subtle);
    font-weight: 500;
  }

  .post-thumb {
    width: 80px;
    height: 60px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
    align-self: center;
  }
</style>
{% endblock %}

{% block content %}
  <div>
    {# Author block #}
    {% if author %}
    <div class="index-author">
      {% if author.profile.picture %}
        <img src="{{ author.profile.picture }}" alt="{{ author.profile.display_name or author.profile.name }}" class="index-avatar" />
      {% else %}
        <div class="index-avatar-placeholder" aria-hidden="true">
          {{ (author.profile.display_name or author.profile.name or "?")[0] | upper }}
        </div>
      {% endif %}
      <div class="index-author-meta">
        <div class="index-author-name">{{ author.profile.display_name or author.profile.name or site.title }}</div>
        {% if author.profile.about %}
          <p class="index-author-bio">{{ author.profile.about }}</p>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Post list #}
    {% if articles.length > 0 %}
      <p class="section-label">Writing</p>
      <ul class="post-list" role="list">
        {% for article in articles %}
        <li class="post-item">
          <a href="/{{ article.slug }}.html" class="post-link {% if article.image %}post-link-with-image{% endif %}">
            <div>
              <h2 class="post-title">{{ article.title }}</h2>
              {% if article.summary %}
                <p class="post-summary">{{ article.summary }}</p>
              {% endif %}
              <div class="post-meta">
                <time datetime="{{ article.published_at | date('iso') }}">{{ article.published_at | date("Y-m-d") }}</time>
                {% if article.readingTime %}
                  <span class="post-meta-sep">·</span>
                  <span>{{ article.readingTime }} min</span>
                {% endif %}
              </div>
              {% if article.tags.length %}
                <div class="post-tags">
                  {% for tag in article.tags | slice(0, 4) %}
                    <span class="post-tag">#{{ tag }}</span>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
            {% if article.image %}
              <img src="{{ article.image }}" alt="" class="post-thumb" loading="lazy" aria-hidden="true" />
            {% endif %}
          </a>
        </li>
        {% endfor %}
      </ul>
    {% else %}
      <p style="color: var(--ink-muted); font-size: 0.9375rem;">No posts yet.</p>
    {% endif %}
  </div>
{% endblock %}
