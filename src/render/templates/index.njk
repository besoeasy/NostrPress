{% extends "layout.njk" %}

{% set pageTitle = site.title %}
{% set pageDescription = site.description %}
{% set canonicalUrl = pathPrefix %}
{% set ogType = "website" %}
{% set ogImage = articles[0].image if articles.length > 0 and articles[0].image else "" %}

{% block additionalHead %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "{{ site.title }}",
  "description": "{{ site.description }}",
  {% if author %}"author": {
    "@type": "Person",
    "name": "{{ author.profile.display_name or author.profile.name }}",
    {% if author.profile.about %}"description": {{ author.profile.about | dump | safe }},{% endif %}
    {% if author.profile.picture %}"image": "{{ author.profile.picture }}",{% endif %}
    {% if author.profile.website %}"url": "{{ author.profile.website }}",{% endif %}
    "sameAs": [
      {% if author.npub %}"https://nosta.me/{{ author.npub }}"{% endif %}{% if author.profile.twitter %},{% endif %}
      {% if author.profile.twitter %}"https://twitter.com/{{ author.profile.twitter }}"{% endif %}{% if author.profile.github %},{% endif %}
      {% if author.profile.github %}"https://github.com/{{ author.profile.github }}"{% endif %}
    ]
  },{% endif %}
  "blogPost": [
    {% for article in articles | slice(0, 10) %}
    {
      "@type": "BlogPosting",
      "headline": {{ article.title | dump | safe }},
      {% if article.summary %}"description": {{ article.summary | dump | safe }},{% endif %}
      "url": "{{ pathPrefix }}{{ article.slug }}.html",
      "datePublished": "{{ article.published_at | date('iso') }}",
      {% if article.modified_at %}"dateModified": "{{ (article.modified_at * 1000) | date('iso') }}",{% endif %}
      {% if article.image %}"image": "{{ article.image }}",{% endif %}
      "author": {
        "@type": "Person",
        "name": "{{ author.profile.display_name or author.profile.name }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
<style>
  /* ── Index-page styles ──────────────────────────── */

  /* Author block at top */
  .index-author {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .index-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }
  .index-avatar-placeholder {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--surface-alt);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .index-author-meta { flex: 1; min-width: 0; }
  .index-author-name {
    font-size: 1.125rem;
    font-weight: 650;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.15s;
  }
  .index-author-name:hover { opacity: 0.7; }
  .index-author-bio {
    margin-top: 0.3rem;
    font-size: 0.9375rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 52ch;
  }
  /* Social icon row */
  .index-author-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
  .profile-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 7px;
    color: var(--ink-muted);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .profile-link:hover {
    background: var(--surface-alt);
    color: var(--ink);
  }
  .profile-link svg { width: 16px; height: 16px; }

  /* Section heading */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 1.5rem;
  }

  /* ── Article list ─────────────────────────────── */
  .post-list {
    list-style: none;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }
  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-link:hover { opacity: 0.7; }

  .post-link-with-image {
    grid-template-columns: 1fr 80px;
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.4;
    margin-bottom: 0.25rem;
  }

  .post-summary {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--ink-subtle);
  }
  .post-meta-sep { opacity: 0.4; }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }
  .post-tag {
    font-size: 0.75rem;
    color: var(--ink-subtle);
    font-weight: 500;
  }

  .post-thumb {
    width: 80px;
    height: 60px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
    align-self: center;
  }
</style>
{% endblock %}

{% block content %}
  <div>
    {# Author block #}
    {% if author %}
    <div class="index-author">
      {% if author.profile.picture %}
        <img src="{{ author.profile.picture }}" alt="{{ author.profile.display_name or author.profile.name }}" class="index-avatar" />
      {% else %}
        <div class="index-avatar-placeholder" aria-hidden="true">
          {{ (author.profile.display_name or author.profile.name or "?")[0] | upper }}
        </div>
      {% endif %}
      <div class="index-author-meta">
        <a href="{{ pathPrefix }}" class="index-author-name">{{ author.profile.display_name or author.profile.name or site.title }}</a>
        {% if author.profile.about %}
          <p class="index-author-bio">{{ author.profile.about }}</p>
        {% endif %}
        <nav class="index-author-links" aria-label="Author links">
          {% if author.profile.website %}
          <a href="{{ author.profile.website }}" target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="Website">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
          </a>
          {% endif %}
          {% if author.profile.twitter %}
          <a href="https://twitter.com/{{ author.profile.twitter }}" target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="Twitter / X">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          {% endif %}
          {% if author.profile.github %}
          <a href="https://github.com/{{ author.profile.github }}" target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="GitHub">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013.01-.4c1.02.004 2.05.14 3.01.4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          {% endif %}
          {% if author.npub %}
          <a href="https://nosta.me/{{ author.npub }}" target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="Nostr profile">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/></svg>
          </a>
          {% endif %}
          {% if author.profile.lud16 %}
          <a href="lightning:{{ author.profile.lud16 }}" class="profile-link" aria-label="Lightning tip">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/></svg>
          </a>
          {% endif %}
          {% if author.profile.telegram %}
          <a href="https://t.me/{{ author.profile.telegram }}" target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="Telegram">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          {% endif %}
        </nav>
      </div>
    </div>
    {% endif %}

    {# Post list #}
    {% if articles.length > 0 %}
      <p class="section-label">Writing</p>
      <ul class="post-list" role="list">
        {% for article in articles %}
        <li class="post-item">
          <a href="{{ pathPrefix }}{{ article.slug }}.html" class="post-link {% if article.image %}post-link-with-image{% endif %}">
            <div>
              <h2 class="post-title">{{ article.title }}</h2>
              {% if article.summary %}
                <p class="post-summary">{{ article.summary }}</p>
              {% endif %}
              <div class="post-meta">
                <time datetime="{{ article.published_at | date('iso') }}">{{ article.published_at | date("Y-m-d") }}</time>
                {% if article.readingTime %}
                  <span class="post-meta-sep">·</span>
                  <span>{{ article.readingTime }} min</span>
                {% endif %}
              </div>
              {% if article.tags.length %}
                <div class="post-tags">
                  {% for tag in article.tags | slice(0, 4) %}
                    <span class="post-tag">#{{ tag }}</span>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
            {% if article.image %}
              <img src="{{ article.image }}" alt="" class="post-thumb" loading="lazy" aria-hidden="true" />
            {% endif %}
          </a>
        </li>
        {% endfor %}
      </ul>
    {% else %}
      <p style="color: var(--ink-muted); font-size: 0.9375rem;">No posts yet.</p>
    {% endif %}
  </div>
{% endblock %}
