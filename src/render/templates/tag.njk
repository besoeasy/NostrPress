{% extends "layout.njk" %}

{% set pageTitle = "#" ~ tag ~ " · " ~ site.title %}
{% set pageDescription = "Articles tagged with #" ~ tag %}
{% set canonicalUrl = pathPrefix ~ "tags/" ~ (tagSlug or tag) ~ "/" %}
{% set ogType = "website" %}
{% set ogImage = "" %}

{% block additionalHead %}
<style>
  .tag-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }
  .tag-back:hover { color: var(--ink); }
  .tag-back svg { width: 15px; height: 15px; }

  .tag-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .tag-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 0.5rem;
  }
  .tag-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.2;
  }
  .tag-count {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--ink-muted);
  }

  /* reuse post-list styles from index */
  .post-list { list-style: none; }
  .post-item { border-bottom: 1px solid var(--border); }
  .post-item:first-child { border-top: 1px solid var(--border); }
  .post-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-link:hover { opacity: 0.7; }
  .post-link-with-image { grid-template-columns: 1fr 80px; }
  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.4;
    margin-bottom: 0.25rem;
  }
  .post-summary {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--ink-subtle);
  }
  .post-meta-sep { opacity: 0.4; }
  .post-thumb {
    width: 80px;
    height: 60px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
    align-self: center;
  }
</style>
{% endblock %}

{% block content %}
  <a href="{{ pathPrefix }}" class="tag-back" aria-label="Back to all posts">
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    All posts
  </a>

  <header class="tag-header">
    <p class="tag-eyebrow">Tag</p>
    <h1 class="tag-title">#{{ tag }}</h1>
    <p class="tag-count">{{ articles.length }} {{ 'post' if articles.length == 1 else 'posts' }}</p>
  </header>

  <ul class="post-list" role="list">
    {% for article in articles %}
    <li class="post-item">
      <a href="{{ pathPrefix }}{{ article.slug }}.html" class="post-link {% if article.image %}post-link-with-image{% endif %}">
        <div>
          <h2 class="post-title">{{ article.title }}</h2>
          {% if article.summary %}
            <p class="post-summary">{{ article.summary }}</p>
          {% endif %}
          <div class="post-meta">
            <time datetime="{{ article.published_at | date('iso') }}">{{ article.published_at | date("Y-m-d") }}</time>
            {% if article.readingTime %}
              <span class="post-meta-sep">·</span>
              <span>{{ article.readingTime }} min</span>
            {% endif %}
          </div>
        </div>
        {% if article.image %}
          <img src="{{ article.image }}" alt="" class="post-thumb" loading="lazy" aria-hidden="true" />
        {% endif %}
      </a>
    </li>
    {% endfor %}
  </ul>
{% endblock %}
