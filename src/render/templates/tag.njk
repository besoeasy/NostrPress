{% extends "layout.njk" %}

{% set pageTitle = "#" ~ tag ~ " · " ~ site.title %}
{% set pageDescription = "Articles tagged with #" ~ tag %}
{% set canonicalUrl = pathPrefix ~ "tags/" ~ (tagSlug or tag) ~ "/" %}
{% set ogType = "website" %}
{% set ogImage = "" %}

{% block additionalHead %}
<style>
  .tag-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }
  .tag-back:hover { color: var(--ink); }
  .tag-back svg { width: 15px; height: 15px; }

  .tag-header {
    margin-bottom: 2.5rem;
  }
  .tag-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 0.5rem;
  }
  .tag-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.2;
  }
  .tag-count {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--ink-muted);
  }

  /* reuse post-list styles from index */
  .post-list { list-style: none; }
  .post-item { border-bottom: 1px solid var(--border); }
  .post-item:first-child { border-top: 1px solid var(--border); }
  .post-link {
    display: block;
    padding: 1.125rem 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }
  .post-link:hover {
    transform: translateX(3px);
    opacity: 0.8;
  }
  .post-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.45;
    margin-bottom: 0.2rem;
  }
  .post-summary {
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 0.45rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-subtle);
  }
  .post-meta-sep { opacity: 0.35; }
</style>
{% endblock %}

{% block content %}
  <a href="{{ pathPrefix }}" class="tag-back" aria-label="Back to all posts">
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    All posts
  </a>

  <header class="tag-header">
    <p class="tag-eyebrow">Tag</p>
    <h1 class="tag-title">#{{ tag }}</h1>
    <p class="tag-count">{{ articles.length }} {{ 'post' if articles.length == 1 else 'posts' }}</p>
  </header>

  <ul class="post-list" role="list">
    {% for article in articles %}
    <li class="post-item">
      <a href="{{ pathPrefix }}{{ article.slug }}.html" class="post-link">
        <h2 class="post-title">{{ article.title }}</h2>
        {% if article.summary %}
          <p class="post-summary">{{ article.summary }}</p>
        {% endif %}
        <div class="post-meta">
          <time datetime="{{ article.published_at | date('iso') }}">{{ article.published_at | date("Y-m-d") }}</time>
          {% if article.readingTime %}
            <span class="post-meta-sep">·</span>
            <span>{{ article.readingTime }} min</span>
          {% endif %}
        </div>
      </a>
    </li>
    {% endfor %}
  </ul>
{% endblock %}
