<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="author" content="{{ author.profile.display_name or author.profile.name or site.title }}" />
    <meta name="generator" content="NostrPress" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a0a0a" />
    {% if canonicalUrl %}
    <link rel="canonical" href="{{ canonicalUrl }}" />
    {% endif %}

    <!-- Favicon and Icons -->
    <link rel="icon" type="image/x-icon" href="{{ pathPrefix }}favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ pathPrefix }}apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ pathPrefix }}favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ pathPrefix }}favicon-16x16.png" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:type" content="{{ ogType or 'website' }}" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:locale" content="en_US" />
    {% if canonicalUrl %}
    <meta property="og:url" content="{{ canonicalUrl }}" />
    {% endif %}
    {% if ogImage %}
    <meta property="og:image" content="{{ ogImage }}" />
    <meta property="og:image:secure_url" content="{{ ogImage }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ pageTitle }}" />
    {% endif %}
    {% if ogType == 'article' %}
    <meta property="article:published_time" content="{{ article.published_at | date('iso') }}" />
    {% if article.modified_at %}
    <meta property="article:modified_time" content="{{ article.modified_at * 1000 | date('iso') }}" />
    {% endif %}
    <meta property="article:author" content="{{ author.profile.display_name or author.profile.name }}" />
    {% for tag in article.tags %}
    <meta property="article:tag" content="{{ tag }}" />
    {% endfor %}
    {% endif %}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    {% if ogImage %}
    <meta name="twitter:image" content="{{ ogImage }}" />
    <meta name="twitter:image:alt" content="{{ pageTitle }}" />
    {% endif %}
    {% if author.profile.twitter %}
    <meta name="twitter:creator" content="@{{ author.profile.twitter }}" />
    {% endif %}

    <!-- Nostr Metadata -->
    {% if author.npub %}
    <meta name="nostr:npub" content="{{ author.npub }}" />
    {% if author.profile.lud16 %}
    <meta name="lightning" content="{{ author.profile.lud16 }}" />
    {% endif %}
    {% endif %}

    {% block additionalHead %}{% endblock %}

    <!-- Inter variable font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..700;1,14..32,300..700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="{{ pathPrefix }}css/site.css" />
    <link rel="stylesheet" href="{{ pathPrefix }}css/print.css" media="print" />
    <style>
      :root {
        --ink: #0a0a0a;
        --ink-muted: #6b7280;
        --ink-subtle: #9ca3af;
        --surface: #ffffff;
        --surface-alt: #f5f5f5;
        --border: #e5e7eb;
        --accent: #0a0a0a;
        --accent-warm: #d97706;
        font-size: 16px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      /* Minimal custom scrollbar */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--ink-subtle); }
      * { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }

      /* Focus ring */
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 3px;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-optical-sizing: auto;
        background: var(--surface);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        line-height: 1.6;
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        top: -60px;
        left: 1rem;
        z-index: 9999;
        background: var(--ink);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 0 0 6px 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: top 0.2s;
      }
      .skip-link:focus { top: 0; }

      /* ── Main layout ─────────────────────────────────── */
      .site-main {
        min-height: calc(100vh - 56px);
        max-width: 680px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem;
      }

      /* ── Footer ─────────────────────────────────────── */
      .site-footer {
        border-top: 1px solid var(--border);
      }
      .footer-inner {
        max-width: 680px;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .footer-text {
        font-size: 0.8125rem;
        color: var(--ink-subtle);
        display: flex;
        align-items: center;
        gap: 0.375rem;
      }
      .footer-text::before {
        content: '';
        display: inline-block;
        width: 12px;
        height: 1px;
        background: var(--border);
        flex-shrink: 0;
      }
      .footer-text a {
        color: var(--ink-muted);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
      }
      .footer-text a:hover { color: var(--ink); }

      .footer-npub {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        color: var(--ink-subtle);
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        font-family: inherit;
        transition: color 0.15s;
      }
      .footer-npub:hover { color: var(--ink-muted); }
      .footer-npub code {
        font-family: ui-monospace, 'SF Mono', monospace;
        font-size: 0.75rem;
      }

      /* ── Page enter animation ─────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .page-enter {
        animation: fadeUp 0.35s ease-out both;
      }

      /* ── Author profile block (used on index) ─────────── */
      .author-block {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 3.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
      }
      .author-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid var(--border);
      }
      .author-avatar-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--surface-alt);
        border: 2px solid var(--border);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--ink-muted);
      }
      .author-info {}
      .author-name {
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.01em;
        line-height: 1.3;
      }
      .author-bio {
        margin-top: 0.25rem;
        font-size: 0.9rem;
        color: var(--ink-muted);
        line-height: 1.5;
      }
      .author-social {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.6rem;
        flex-wrap: wrap;
      }
      .author-social a {
        font-size: 0.8125rem;
        color: var(--ink-subtle);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
      }
      .author-social a:hover { color: var(--ink); }

      /* ── Selection highlight ──────────────────────────── */
      ::selection {
        background: #0a0a0a;
        color: #fff;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>


    <main id="main-content" class="site-main page-enter" role="main">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <p class="footer-text">
          Built with <a href="https://github.com/besoeasy/NostrPress" target="_blank" rel="noopener noreferrer">NostrPress</a>
        </p>
        {% if author and author.npub %}
        <button
          class="footer-npub"
          onclick="navigator.clipboard.writeText('{{ author.npub }}'); this.querySelector('span').textContent='Copied!'; setTimeout(()=>this.querySelector('span').textContent='{{ author.npub | truncate(20) }}…', 2000)"
          aria-label="Copy Nostr public key"
          title="{{ author.npub }}"
        >
          <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/></svg>
          <code><span>{{ author.npub | truncate(20) }}…</span></code>
        </button>
        {% endif %}
      </div>
    </footer>

    <script src="{{ pathPrefix }}js/site.js" defer></script>
  </body>
</html>
