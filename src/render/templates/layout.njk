<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="author" content="{{ author.profile.display_name or author.profile.name or site.title }}" />
    <meta name="generator" content="NostrPress" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a0a0a" />
    {% if canonicalUrl %}
    <link rel="canonical" href="{{ canonicalUrl }}" />
    {% endif %}

    <!-- Favicon and Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:type" content="{{ ogType or 'website' }}" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:locale" content="en_US" />
    {% if canonicalUrl %}
    <meta property="og:url" content="{{ canonicalUrl }}" />
    {% endif %}
    {% if ogImage %}
    <meta property="og:image" content="{{ ogImage }}" />
    <meta property="og:image:secure_url" content="{{ ogImage }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ pageTitle }}" />
    {% endif %}
    {% if ogType == 'article' %}
    <meta property="article:published_time" content="{{ article.published_at | date('iso') }}" />
    {% if article.modified_at %}
    <meta property="article:modified_time" content="{{ article.modified_at * 1000 | date('iso') }}" />
    {% endif %}
    <meta property="article:author" content="{{ author.profile.display_name or author.profile.name }}" />
    {% for tag in article.tags %}
    <meta property="article:tag" content="{{ tag }}" />
    {% endfor %}
    {% endif %}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    {% if ogImage %}
    <meta name="twitter:image" content="{{ ogImage }}" />
    <meta name="twitter:image:alt" content="{{ pageTitle }}" />
    {% endif %}
    {% if author.profile.twitter %}
    <meta name="twitter:creator" content="@{{ author.profile.twitter }}" />
    {% endif %}

    <!-- Nostr Metadata -->
    {% if author.npub %}
    <meta name="nostr:npub" content="{{ author.npub }}" />
    {% if author.profile.lud16 %}
    <meta name="lightning" content="{{ author.profile.lud16 }}" />
    {% endif %}
    {% endif %}

    {% block additionalHead %}{% endblock %}

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="/css/print.css" media="print" />
    <style>
      :root {
        --ink: #0a0a0a;
        --ink-muted: #6b7280;
        --ink-subtle: #9ca3af;
        --surface: #ffffff;
        --surface-alt: #f9fafb;
        --border: #e5e7eb;
        --accent: #0a0a0a;
        --accent-warm: #f59e0b;
        font-size: 16px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        background: var(--surface);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        line-height: 1.6;
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        top: -60px;
        left: 1rem;
        z-index: 9999;
        background: var(--ink);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 0 0 6px 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: top 0.2s;
      }
      .skip-link:focus { top: 0; }

      /* ── Header / Nav ─────────────────────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .header-inner {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-name {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        text-decoration: none;
        color: var(--ink);
      }

      .site-name-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
      }

      .site-name-text {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1;
      }

      .header-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      .header-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        color: var(--ink-muted);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
      }
      .header-link:hover {
        background: var(--surface-alt);
        color: var(--ink);
      }
      .header-link svg { width: 17px; height: 17px; }

      /* ── Main layout ─────────────────────────────────── */
      .site-main {
        min-height: calc(100vh - 56px - 56px);
        max-width: 760px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem;
      }

      /* ── Footer ─────────────────────────────────────── */
      .site-footer {
        border-top: 1px solid var(--border);
      }
      .footer-inner {
        max-width: 760px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .footer-text {
        font-size: 0.8125rem;
        color: var(--ink-subtle);
      }
      .footer-text a {
        color: var(--ink-muted);
        text-decoration: none;
        font-weight: 500;
      }
      .footer-text a:hover { color: var(--ink); }

      .footer-npub {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        color: var(--ink-subtle);
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        font-family: inherit;
        transition: color 0.15s;
      }
      .footer-npub:hover { color: var(--ink-muted); }
      .footer-npub code {
        font-family: ui-monospace, 'SF Mono', monospace;
        font-size: 0.75rem;
      }

      /* ── Page enter animation ─────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .page-enter {
        animation: fadeUp 0.4s ease both;
      }

      /* ── Author profile block (used on index) ─────────── */
      .author-block {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 3.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
      }
      .author-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid var(--border);
      }
      .author-avatar-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--surface-alt);
        border: 2px solid var(--border);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--ink-muted);
      }
      .author-info {}
      .author-name {
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.01em;
        line-height: 1.3;
      }
      .author-bio {
        margin-top: 0.25rem;
        font-size: 0.9rem;
        color: var(--ink-muted);
        line-height: 1.5;
      }
      .author-social {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.6rem;
        flex-wrap: wrap;
      }
      .author-social a {
        font-size: 0.8125rem;
        color: var(--ink-subtle);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
      }
      .author-social a:hover { color: var(--ink); }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header" role="banner">
      <div class="header-inner">
        <a href="/" class="site-name" aria-label="{{ site.title }} — home">
          {% if author and author.profile.picture %}
            <img src="{{ author.profile.picture }}" alt="" class="site-name-avatar" aria-hidden="true" />
          {% endif %}
          <span class="site-name-text">{{ site.title }}</span>
        </a>

        <nav class="header-links" aria-label="Author links">
          {% if author and author.profile.website %}
          <a href="{{ author.profile.website }}" target="_blank" rel="noopener noreferrer" class="header-link" aria-label="Website">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
          </a>
          {% endif %}
          {% if author and author.profile.twitter %}
          <a href="https://twitter.com/{{ author.profile.twitter }}" target="_blank" rel="noopener noreferrer" class="header-link" aria-label="Twitter / X">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          {% endif %}
          {% if author and author.profile.github %}
          <a href="https://github.com/{{ author.profile.github }}" target="_blank" rel="noopener noreferrer" class="header-link" aria-label="GitHub">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013.01-.4c1.02.004 2.05.14 3.01.4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          {% endif %}
          {% if author and author.npub %}
          <a href="https://nosta.me/{{ author.npub }}" target="_blank" rel="noopener noreferrer" class="header-link" aria-label="Nostr profile">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/></svg>
          </a>
          {% endif %}
          {% if author and author.profile.lud16 %}
          <a href="lightning:{{ author.profile.lud16 }}" class="header-link" aria-label="Lightning tip">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/></svg>
          </a>
          {% endif %}
        </nav>
      </div>
    </header>

    <main id="main-content" class="site-main page-enter" role="main">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <p class="footer-text">
          Built with <a href="https://github.com/besoeasy/NostrPress" target="_blank" rel="noopener noreferrer">NostrPress</a>
        </p>
        {% if author and author.npub %}
        <button
          class="footer-npub"
          onclick="navigator.clipboard.writeText('{{ author.npub }}'); this.querySelector('span').textContent='Copied!'; setTimeout(()=>this.querySelector('span').textContent='{{ author.npub | truncate(20) }}…', 2000)"
          aria-label="Copy Nostr public key"
          title="{{ author.npub }}"
        >
          <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/></svg>
          <code><span>{{ author.npub | truncate(20) }}…</span></code>
        </button>
        {% endif %}
      </div>
    </footer>

    <script src="/js/site.js" defer></script>
  </body>
</html>
