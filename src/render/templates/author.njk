{% extends "layout.njk" %}

{% set pageTitle = site.title ~ " · " ~ (author.profile.display_name or author.profile.name or author.npub) %}
{% set pageDescription = author.profile.about or site.description %}
{% set canonicalUrl = "/author/" %}
{% set ogType = "profile" %}
{% set ogImage = author.profile.picture or "" %}

{% block additionalHead %}
<style>
  /* reuse post-list styles */
  .post-list { list-style: none; }
  .post-item { border-bottom: 1px solid var(--border); }
  .post-item:first-child { border-top: 1px solid var(--border); }
  .post-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-link:hover { opacity: 0.7; }
  .post-link-with-image { grid-template-columns: 1fr 80px; }
  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.4;
    margin-bottom: 0.25rem;
  }
  .post-summary {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--ink-subtle);
  }
  .post-meta-sep { opacity: 0.4; }
  .post-thumb {
    width: 80px;
    height: 60px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
    align-self: center;
  }

  .author-page-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .author-page-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }
  .author-page-avatar-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--surface-alt);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .author-page-meta { flex: 1; min-width: 0; }
  .author-page-name {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: 0.25rem;
  }
  .author-page-npub {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 0.75rem;
    color: var(--ink-subtle);
    margin-bottom: 0.625rem;
    word-break: break-all;
  }
  .author-page-bio {
    font-size: 0.9375rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 52ch;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 1.5rem;
  }
</style>
{% endblock %}

{% block content %}
  <header class="author-page-header">
    {% if author.profile.picture %}
      <img src="{{ author.profile.picture }}" alt="{{ author.profile.display_name or author.profile.name }}" class="author-page-avatar" />
    {% else %}
      <div class="author-page-avatar-placeholder" aria-hidden="true">
        {{ (author.profile.display_name or author.profile.name or "?")[0] | upper }}
      </div>
    {% endif %}
    <div class="author-page-meta">
      <h1 class="author-page-name">{{ author.profile.display_name or author.profile.name or author.npub }}</h1>
      {% if author.npub %}
        <p class="author-page-npub">{{ author.npub }}</p>
      {% endif %}
      {% if author.profile.about %}
        <p class="author-page-bio">{{ author.profile.about }}</p>
      {% endif %}
    </div>
  </header>

  {% if articles.length > 0 %}
    <p class="section-label">All posts</p>
    <ul class="post-list" role="list">
      {% for article in articles %}
      <li class="post-item">
        <a href="/{{ article.slug }}.html" class="post-link {% if article.image %}post-link-with-image{% endif %}">
          <div>
            <h2 class="post-title">{{ article.title }}</h2>
            {% if article.summary %}
              <p class="post-summary">{{ article.summary }}</p>
            {% endif %}
            <div class="post-meta">
              <time datetime="{{ article.published_at | date('iso') }}">{{ article.published_at | date("Y-m-d") }}</time>
              {% if article.readingTime %}
                <span class="post-meta-sep">·</span>
                <span>{{ article.readingTime }} min</span>
              {% endif %}
            </div>
          </div>
          {% if article.image %}
            <img src="{{ article.image }}" alt="" class="post-thumb" loading="lazy" aria-hidden="true" />
          {% endif %}
        </a>
      </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endblock %}
