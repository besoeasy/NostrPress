{% extends "layout.njk" %}

{% set pageTitle = article.title ~ " · " ~ site.title %}
{% set pageDescription = article.excerpt or article.summary or site.description %}
{% set canonicalUrl = pathPrefix ~ article.slug ~ ".html" %}
{% set ogType = "article" %}
{% set ogImage = article.image or "" %}

{% block additionalHead %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ article.title | dump | safe }},
  "image": [{% if article.image %}"{{ article.image }}"{% endif %}],
  "datePublished": "{{ article.published_at | date('iso') }}",
  {% if article.modified_at %}"dateModified": "{{ article.modified_at | date('iso') }}",{% else %}"dateModified": "{{ article.published_at | date('iso') }}",{% endif %}
  "author": {
    "@type": "Person",
    "name": "{{ author.profile.display_name or author.profile.name }}",
    "url": "{{ pathPrefix }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.title }}",
    "logo": { "@type": "ImageObject", "url": "{{ author.profile.picture }}" }
  },
  {% if article.summary %}"description": {{ article.summary | dump | safe }},{% endif %}
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ canonicalUrl }}" }
}
</script>
<style>
  /* ── Article page ─────────────────────────────── */

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }
  .article-back:hover { color: var(--ink); }
  .article-back svg { width: 15px; height: 15px; }

  /* Hero image */
  .article-hero {
    margin: 0 0 2.5rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-alt);
  }
  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Header */
  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--ink-subtle);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .article-meta-sep { opacity: 0.4; }

  .article-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.18;
    color: var(--ink);
    margin-bottom: 1.25rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }
  .article-tag {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.2rem 0.65rem;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .article-tag:hover {
    border-color: transparent;
    background: var(--surface-alt);
    color: var(--ink);
  }

  /* Share / open-on row */
  .article-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.75rem;
  }
  .action-label {
    font-size: 0.8125rem;
    color: var(--ink-subtle);
    font-weight: 500;
    margin-right: 0.25rem;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }
  .action-btn:hover {
    background: var(--surface-alt);
    color: var(--ink);
  }
  .action-btn svg { width: 14px; height: 14px; flex-shrink: 0; }

  .actions-divider {
    width: 1px;
    height: 18px;
    background: var(--border);
    margin: 0 0.125rem;
  }

  /* ── Prose ─────────────────────────────────────── */
  .prose {
    color: var(--ink);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose > * + * { margin-top: 1.5em; }

  .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--ink);
    margin-top: 2.25em;
    margin-bottom: 0.6em;
  }
  .prose h1 { font-size: 1.875rem; }
  .prose h2 { font-size: 1.5rem; }
  .prose h3 { font-size: 1.25rem; }
  .prose h4 { font-size: 1.0625rem; }

  .prose p { color: #1a1a1a; }

  .prose a {
    color: var(--ink);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose a:hover { opacity: 0.65; }

  .prose strong { font-weight: 650; }
  .prose em { color: #333; }

  .prose ul, .prose ol { padding-left: 1.5rem; }
  .prose ul { list-style: disc; }
  .prose ol { list-style: decimal; }
  .prose li + li { margin-top: 0.4em; }

  .prose blockquote {
    border-left: 2px solid var(--accent-warm);
    padding-left: 1.25rem;
    color: var(--ink-muted);
    font-style: italic;
    margin-left: 0;
  }

  .prose code {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: var(--ink);
  }

  .prose pre {
    background: #111;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.85rem;
    color: #d4d4d4;
    line-height: 1.7;
  }

  .prose img {
    border-radius: 8px;
    border: 1px solid var(--border);
    max-width: 100%;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3em 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }
  .prose th, .prose td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .prose th {
    font-weight: 600;
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* ── Related articles ─────────────────────────── */
  .related-section {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .related-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .related-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .related-list {
    list-style: none;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }
  .related-item a {
    display: block;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .related-item a:hover { opacity: 0.7; }
  .related-thumb {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: block;
    margin-bottom: 0.5rem;
    background: var(--surface-alt);
  }
  .related-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin-bottom: 0.25rem;
  }
  .related-date {
    font-size: 0.8125rem;
    color: var(--ink-subtle);
  }

  /* ── Comments ─────────────────────────────────── */
  .comments-section {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .comments-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .comments-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .comment-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .comment {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .comment-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }
  .comment-avatar-placeholder {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .comment-body { flex: 1; min-width: 0; }
  .comment-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .comment-author {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink);
  }
  .comment-date {
    font-size: 0.8rem;
    color: var(--ink-subtle);
  }
  .comment-text {
    font-size: 0.9375rem;
    color: #1a1a1a;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
{% endblock %}

{% block content %}
<article itemscope itemtype="https://schema.org/BlogPosting">
  <meta itemprop="headline" content="{{ article.title }}" />
  <meta itemprop="description" content="{{ pageDescription }}" />
  <meta itemprop="datePublished" content="{{ article.published_at | date('iso') }}" />
  {% if article.modified_at %}
  <meta itemprop="dateModified" content="{{ article.modified_at * 1000 | date('iso') }}" />
  {% endif %}
  <meta itemprop="author" content="{{ author.profile.display_name or author.profile.name }}" />
  {% if article.image %}
  <meta itemprop="image" content="{{ article.image }}" />
  {% endif %}

  <a href="{{ pathPrefix }}" class="article-back" aria-label="Back to all posts">
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    All posts
  </a>

  {% if article.image %}
  <div class="article-hero">
    <img src="{{ article.image }}" alt="{{ article.title }}" itemprop="image" />
  </div>
  {% endif %}

  <header class="article-header">
    <div class="article-meta">
      <time datetime="{{ article.published_at | date('iso') }}" itemprop="datePublished">{{ article.published_at | date("Y-m-d") }}</time>
      {% if article.readingTime %}
        <span class="article-meta-sep">·</span>
        <span>{{ article.readingTime }} min read</span>
      {% endif %}
      {% if article.wordCount %}
        <span class="article-meta-sep">·</span>
        <span>{{ article.wordCount }} words</span>
      {% endif %}
    </div>

    <h1 class="article-title" itemprop="headline">{{ article.title }}</h1>

    {% if article.tags.length %}
      <div class="article-tags" aria-label="Tags">
        {% for tag in article.tags %}
          <a href="{{ pathPrefix }}tags/{{ article.tagSlugMap[tag] or tag }}/" class="article-tag" itemprop="keywords">#{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}

    <!-- Share -->
    <div class="article-actions" aria-label="Share this article">
      <span class="action-label">Share</span>
      <a href="https://twitter.com/intent/tweet?text={{ pageTitle | urlencode }}&url={{ canonicalUrl | urlencode }}" target="_blank" rel="noopener noreferrer" class="action-btn" aria-label="Share on Twitter">
        <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Twitter
      </a>
      <a href="https://t.me/share/url?url={{ canonicalUrl | urlencode }}&text={{ pageTitle | urlencode }}" target="_blank" rel="noopener noreferrer" class="action-btn" aria-label="Share on Telegram">
        <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Telegram
      </a>
      <button onclick="navigator.clipboard.writeText(window.location.href); this.textContent='Copied!'; setTimeout(()=>this.textContent='Copy link', 2000)" class="action-btn" aria-label="Copy link">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Copy link
      </button>

      {% if article.naddr %}
      <span class="actions-divider" aria-hidden="true"></span>
      <span class="action-label">Open on</span>
      <a href="https://habla.news/a/{{ article.naddr }}" target="_blank" rel="noopener noreferrer" class="action-btn">Habla</a>
      <a href="https://yakihonne.com/article/{{ article.naddr }}" target="_blank" rel="noopener noreferrer" class="action-btn">Yakihonne</a>
      <a href="https://primal.net/e/{{ article.naddr }}" target="_blank" rel="noopener noreferrer" class="action-btn">Primal</a>
      {% endif %}
    </div>
  </header>

  <div class="prose" itemprop="articleBody">
    {{ article.html | safe }}
  </div>
</article>

<!-- Related articles -->
{% if relatedArticles.length %}
  <section class="related-section" aria-labelledby="related-heading">
    <p class="related-label" id="related-heading">Related</p>
    <ul class="related-list" role="list">
      {% for related in relatedArticles %}
        <li class="related-item">
          <a href="{{ pathPrefix }}{{ related.slug }}.html">
            {% if related.image %}
              <img src="{{ related.image }}" alt="" class="related-thumb" loading="lazy" aria-hidden="true" />
            {% else %}
              <div class="related-thumb" style="display:flex;align-items:center;justify-content:center;">
                <svg width="24" height="24" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            {% endif %}
            <div class="related-title">{{ related.title }}</div>
            <div class="related-date">{{ related.published_at | date("Y-m-d") }}</div>
          </a>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endif %}

<!-- Comments -->
{% if article.comments.length %}
  <section class="comments-section" aria-labelledby="comments-heading">
    <p class="comments-label" id="comments-heading">
      {{ article.comments.length }} {{ 'comment' if article.comments.length == 1 else 'comments' }}
    </p>
    <ul class="comment-list" role="list">
      {% for comment in article.comments %}
        <li class="comment">
          {% if comment.author_picture %}
            <img src="{{ comment.author_picture }}" alt="{{ comment.author_name or 'Anonymous' }}" class="comment-avatar" loading="lazy" />
          {% else %}
            <div class="comment-avatar-placeholder" aria-hidden="true">
              {{ (comment.author_name or comment.pubkey or "?")[0] | upper }}
            </div>
          {% endif %}
          <div class="comment-body">
            <div class="comment-header">
              <span class="comment-author">{{ comment.author_name or comment.pubkey.slice(0, 8) + '…' }}</span>
              <time class="comment-date" datetime="{{ comment.created_at * 1000 | date('iso') }}">{{ (comment.created_at * 1000) | date("Y-m-d") }}</time>
            </div>
            <p class="comment-text">{{ comment.content }}</p>
          </div>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endif %}
{% endblock %}
